# ===========================================
# .env.example — 이 파일을 복사해 .env 로 저장한 뒤, 아래 값을 본인 환경에 맞게 수정하세요.
# 필수: KIS_APP_KEY, KIS_APP_SECRET, KIS_ACCOUNT_NO, SLACK_WEBHOOK_URL 는 반드시 .env 에 설정해야 합니다.
# ===========================================

# ----- 필수 (반드시 설정) -----
# KIS_APP_KEY="your_app_key"
# KIS_APP_SECRET="your_app_secret"
# KIS_ACCOUNT_NO="your_account_no"
# SLACK_WEBHOOK_URL="https://hooks.slack.com/..."

# ----- 거래 모드 -----
# True = 모의투자, False = 실전 매매 (실전 전 반드시 한번 더 확인)
MOCK_TRADE="False"

# ----- 대상 종목 -----
# 고정 종목 사용 시: 쉼표로 구분한 종목코드. USE_VOLUME_RANK / USE_CONDITION_SEARCH 가 False 일 때만 사용
TARGET_SYMBOLS="047040, 242040, 293580"

# ----- 종목 소스 (둘 다 False 면 위 TARGET_SYMBOLS 사용) -----
# True = HTS 조건검색 결과로 종목 갱신 (HTS 설치·로그인 필요)
USE_CONDITION_SEARCH=False
# True = 거래량 상위 API 로 종목 발굴 (HTS 없이 사용 가능, 조건검색 대체용)
USE_VOLUME_RANK=True

# ----- 필터링: 거래량/조건검색 사용 시 -----
# 가져올 최대 종목 수. LLM이 걸러주므로 후보를 넓게 잡아도 OK
CONDITION_SEARCH_MAX=60
# 가격 필터(원): 이 범위 밖 종목 제외. 동전주·고가주 제한용
CONDITION_MIN_PRICE=1000
CONDITION_MAX_PRICE=80000

# ----- 자금 관리 -----
# 예수금의 몇 %를 매매에 쓸지 (0~1). 0.7 = 70%. 종목당 금액을 늘리려면 0.7~0.8 등으로 조정
BUDGET_RATIO=0.7

# ----- 동시 보유 종목 수 & 재검색 -----
# 최대 N 종목까지 동시 보유. 늘리면 거래 회전이 많아짐
MAX_SLOTS=7
# 빈 슬롯이 있을 때, 이 간격(초)마다 새 종목 재검색. 짧을수록 더 자주 탐색 (과다 호출 주의)
SCAN_INTERVAL=180

# ----- 진입 시간 (매수 허용 구간) -----
# 분: 장 시작 후 이 분이 지나야 매수 (0 = 장 시작부터). LLM 사용 시 초반 기회도 포착 가능
ENTRY_NO_BEFORE_MINUTE=15
# 시: 이 시각 이후에는 신규 매수 금지 (15 = 15:00)
ENTRY_NO_AFTER_HOUR=15
# 분: 15:20 이면 HOUR=15, MINUTE=20
ENTRY_NO_AFTER_MINUTE=20

# ----- 진입 필터 (갭·거래량·상승률) -----
# ※ USE_LLM_ADVISOR=True 시 아래 3개 필터는 코드에서 자동 바이패스됨 (LLM이 판단)
# 전일 종가 대비 갭업 이 % 이상이면 매수 스킵. 0 = 미적용
ENTRY_GAP_UP_PCT=0
# 돌파 시점 거래량이 직전 20봉 평균의 이 배수 이상일 때만 매수. 0 = 미적용
ENTRY_VOLUME_RATIO=0
# 당일 시가 대비 현재가가 이 % 이상 이미 오른 종목은 매수 스킵. 0 = 미적용
ENTRY_MAX_UP_FROM_OPEN_PCT=0

# ----- 변동성 돌파 전략 -----
# True = 전일 변동성에 따라 K를 0.3/0.5/0.7 로 자동 조정
# USE_ADAPTIVE_K=True

# ----- 일별 리스크 관리 -----
# 당일 실현손실이 총자산 대비 이 % 이하면 신규 매수 중단 (예: -4 = -4%)
DAILY_LOSS_LIMIT_PCT=-4.0
# 이 횟수 연패 시 다음 매수 예산을 줄임
MAX_CONSECUTIVE_LOSSES=4
# 연패 시 적용할 예산 비율 (0.7 = 70%만 사용)
BUDGET_CUT_ON_STREAK=0.7
# 당일 체결 건수(BUY+SELL) 이 값 초과 시 신규 매수만 중단. LLM이 필터링하므로 여유 있게
MAX_DAILY_TRADES=30

# ----- ATR 손절 (변동성 기반 손절가) -----
# True = 고정 % 대신 ATR 기반 동적 손절 (변동성 큰 종목에 유리)
USE_ATR_STOP=True
# ATR 계산 기간(일)
ATR_PERIOD=20
# 손절가 = 매수가 - (ATR × 이 배수). 2.0 = 변동성의 2배 아래에서 손절
ATR_MULTIPLIER=1.5

# ----- 시장 지수 필터 (하락장 회피) -----
# True = 지수가 N일 이평 아래면 신규 매수 금지. LLM 사용 시 끄고 LLM에 위임 가능
USE_MARKET_FILTER=False
# 1001=코스닥, 0001=코스피
MARKET_INDEX_CODE=1001
# 이동평균 기간 (일). 5일선 추천
MARKET_MA_PERIOD=5

# ----- 매수 주문 방식 -----
# 현재가 + N호가 지정가 주문 (0=시장가). 미체결 방지용
BUY_PRICE_TICK_OFFSET=2

# ----- RSI 이익실현 -----
# 보유 중 RSI가 이 값 이상이면 매도 신호 발생 (0=비활성). 과매수 구간에서 이익 실현
RSI_EXIT_THRESHOLD=70.0

# ----- 종목 스코어링 (거래량/조건검색 사용 시) -----
# True = 후보를 스코어로 정렬한 뒤 상위 MAX_SLOTS 개만 진입 (품질 필터 역할)
USE_STOCK_SCORING=True

# ----- LLM 매수 어드바이저 (Gemini via Vertex AI) -----
# True = 전략 BUY 신호 발생 후 Gemini LLM이 한 번 더 검증 (거부 시 매수 스킵)
USE_LLM_ADVISOR=False
# Vertex AI 서비스 계정 (우선) — 프로젝트 루트 기준 상대경로 또는 절대경로
VERTEX_SERVICE_ACCOUNT="gemini_service_account.json"
# Vertex AI 리전 (기본: asia-northeast3 = 서울)
# VERTEX_REGION="asia-northeast3"
# 비워두면 서비스 계정 JSON의 project_id 사용
# VERTEX_PROJECT_ID=""
# (폴백) Gemini 직접 API 키 — Vertex AI 실패 시 사용. 비워두면 Vertex만 사용
# GEMINI_API_KEY=""
# 사용할 Gemini 모델
GEMINI_MODEL="gemini-2.5-flash"
# 일일 최대 LLM 호출 횟수 (초과 시 매수 허용 = fail-open)
LLM_MAX_DAILY_CALLS=50
# LLM 매수 거부 시 해당 종목 재시도 대기 시간 (초, 기본 1800=30분)
LLM_REJECT_COOLDOWN=1800

# ----- 기타 -----
# 제외할 종목 코드 (쉼표 구분). 파생ETF 미신청 종목 등
# BLACKLIST_SYMBOLS="412570"
# DB·상태 파일 기준 디렉터리 (비우면 프로젝트 루트)
# DATA_DIR=""
