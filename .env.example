# ===========================================
# .env.example — 이 파일을 복사해서 .env 로 저장한 뒤, 아래 값들을 본인 값으로 채우세요.
# ===========================================

# ----- 필수 -----
KIS_APP_KEY="your_kis_app_key"
KIS_APP_SECRET="your_kis_app_secret"
KIS_ACCOUNT_NO="your_account_no"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# 거래 모드: True=모의, False=실제
MOCK_TRADE=True

# ----- 전략·종목 (선택) -----
# VOLATILITY_BREAKOUT_K=0.5
# USE_ADAPTIVE_K=True
# BUDGET_RATIO=0.5
# TARGET_SYMBOLS="005930,000660"

# ----- 종목 소스: 거래량 상위 / HTS 조건검색 (선택) -----
# USE_VOLUME_RANK=False
# USE_CONDITION_SEARCH=False
# KIS_USER_ID=""
# CONDITION_SEARCH_SEQ="0"
# CONDITION_SEARCH_MAX=10
# CONDITION_MIN_PRICE=1000
# CONDITION_MAX_PRICE=99999999
# BLACKLIST_SYMBOLS=""

# ----- 슬롯·재검색 (선택) -----
# MAX_SLOTS=3
# SCAN_INTERVAL=60

# ----- 진입 필터: 시간·갭·거래량 (선택) -----
# ENTRY_NO_BEFORE_MINUTE=30
# ENTRY_NO_AFTER_HOUR=14
# ENTRY_NO_AFTER_MINUTE=30
# ENTRY_GAP_UP_PCT=5.0
# ENTRY_MAX_UP_FROM_OPEN_PCT=30.0
# ENTRY_VOLUME_RATIO=1.5

# ----- 일별 리스크 (선택) -----
# DAILY_LOSS_LIMIT_PCT=-2.0
# MAX_CONSECUTIVE_LOSSES=3
# BUDGET_CUT_ON_STREAK=0.5
# MAX_DAILY_TRADES=6

# ----- ATR 손절 (선택) -----
# USE_ATR_STOP=False
# ATR_PERIOD=20
# ATR_MULTIPLIER=1.5

# ----- 종목 스코어링 (선택) -----
# USE_STOCK_SCORING=False

# ----- 기타 (선택) -----
# DATA_DIR=""
